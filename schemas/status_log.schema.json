{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "status_log.json",
  "type": "object",
  "required": ["schema_version", "statuses"],
  "properties": {
    "schema_version": { "type": "integer", "minimum": 2 },
    "statuses": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["date", "status", "note"],
        "properties": {
          "task_id": { "type": "string" },
          "date": { "type": "string" },
          "title_match": { "type": "string" },
          "title_contains": { "type": "string" },
          "aliases": { "type": "array", "items": { "type": "string" } },
          "status": { "type": "string" },
          "note": { "type": "string" },
          "suggested_date": { "type": "string" },
          "suggested_start": { "type": "string" },
          "suggested_end": { "type": "string" },
          "dependency_note": { "type": "string" },
          "resolution_state": { "type": "string" }
        },
        "additionalProperties": true
      }
    }
  },
  "additionalProperties": true
}
